<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Edit Fire Report - BFP Alert</title>
  <link rel="stylesheet" href="/css/style.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
</head>
<body>
  <div class="sidebar">
    <div class="sidebar-header">
      BFP Alert
    </div>
    <div class="sidebar-nav">
      <a href="/dashboard"><i class="fas fa-th-large"></i> Dashboard</a>
      <% if (user.role !== 'admin') { %>
        <a href="/submit-report"><i class="fas fa-file-medical"></i> Submit Report</a>
      <% } %>
      <a href="/auth/profile"><i class="fas fa-user-circle"></i> Profile</a>
      <a href="/auth/logout"><i class="fas fa-sign-out-alt"></i> Logout</a>
    </div>
  </div>

  <div class="main-content">
    <div class="top-bar">
      <div style="display: flex; align-items: center;">
        <a href="/dashboard" style="color: white; margin-right: 15px;"><i class="fas fa-arrow-left"></i></a>
        <h2>Edit Incident Report: <%= report.report_id %></h2>
      </div>
      <div class="user-display">
        <span style="font-size: 0.9rem; color: white; font-weight: 600;">Editor: <span style="color: var(--fire-gold);"><%= user.username %></span></span>
      </div>
    </div>

    <div class="content-padding">
      <div class="form-container">
        <div class="form-header">
          <h3>UPDATE INCIDENT INFORMATION</h3>
          <p>Modify the details of the reported fire incident.</p>
        </div>
        <div class="form-body">
          <form action="/reports/edit/<%= report.id %>" method="POST" enctype="multipart/form-data">
            <div class="form-grid">
              <div class="form-group">
                <label>Full Name</label>
                <input type="text" name="full_name" value="<%= report.full_name %>" required>
              </div>
              <div class="form-group">
                <label>Contact Number</label>
                <input type="text" name="contact_number" value="<%= report.contact_number %>" required>
              </div>
              <div class="form-group">
                <label>Incident Location (Street/Bldg)</label>
                <input type="text" name="incident_location" value="<%= report.incident_location %>" required>
              </div>
              <div class="form-group">
                <label>Barangay / City</label>
                <input type="text" name="barangay_city" value="<%= report.barangay_city %>" required>
              </div>
              <div class="form-group">
                <label>Fire Severity Level</label>
                <select name="severity" required>
                  <option value="Low" <%= report.severity === 'Low' ? 'selected' : '' %>>Low (Smoke/Small Fire)</option>
                  <option value="Medium" <%= report.severity === 'Medium' ? 'selected' : '' %>>Medium (Developing Fire)</option>
                  <option value="High" <%= report.severity === 'High' ? 'selected' : '' %>>High (Structure on Fire)</option>
                </select>
              </div>
              <div class="form-group">
                <label>Update Photo (Optional)</label>
                <input type="file" name="photo" accept="image/*">
                <% if (report.photo_path) { %>
                  <span style="font-size: 0.65rem; color: var(--text-muted); display: block; margin-top: 5px;">Current photo: <a href="<%= report.photo_path %>" target="_blank" style="color: var(--primary-red);">View Current</a></span>
                <% } %>
              </div>
              <div class="form-group full-width">
                <label>Description / Additional Details</label>
                <textarea name="description" rows="4"><%= report.description %></textarea>
              </div>
            </div>
            <button type="submit" class="btn-submit">SAVE CHANGES</button>
          </form>
        </div>
      </div>
    </div>
  </div>
</body>
</html>
