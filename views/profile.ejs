<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>User Profile - BFP Alert</title>
  <link rel="stylesheet" href="/css/style.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
</head>
<body>
  <div class="sidebar">
    <div class="sidebar-header">
      BFP Alert
    </div>
    <div class="sidebar-nav">
      <a href="/dashboard"><i class="fas fa-th-large"></i> Dashboard</a>
      <% if (user.role !== 'admin') { %>
        <a href="/submit-report"><i class="fas fa-file-medical"></i> Submit Report</a>
      <% } %>
      <a href="/auth/profile" class="active"><i class="fas fa-user-circle"></i> Profile</a>
      <a href="/auth/logout"><i class="fas fa-sign-out-alt"></i> Logout</a>
    </div>
  </div>

  <div class="main-content">
    <div class="top-bar">
      <h2>My Profile</h2>
      <div class="user-display">
        <span style="font-size: 0.9rem; color: var(--text-dark); font-weight: 600;"><%= user.username %> (<span style="color: var(--primary-red);"><%= user.role %></span>)</span>
      </div>
    </div>

    <div class="content-padding">
      <div class="form-container" style="max-width: 600px;">
        <div class="form-header">
          <h3>ACCOUNT SETTINGS</h3>
          <p>Update your personal information and password.</p>
        </div>
        <div class="form-body">
          <% if (typeof error !== 'undefined' && error) { %> 
            <div style="background-color: #f8d7da; color: #842029; padding: 12px; border-radius: 4px; margin-bottom: 20px; font-size: 0.85rem; border: 1px solid #f5c2c7;">
              <i class="fas fa-exclamation-circle" style="margin-right: 8px;"></i> <%= error %>
            </div> 
          <% } %>
          <% if (typeof success !== 'undefined' && success) { %> 
            <div style="background-color: #d1e7dd; color: #0f5132; padding: 12px; border-radius: 4px; margin-bottom: 20px; font-size: 0.85rem; border: 1px solid #badbcc;">
              <i class="fas fa-check-circle" style="margin-right: 8px;"></i> <%= success %>
            </div> 
          <% } %>

          <form action="/auth/profile" method="POST">
            <div class="form-group" style="margin-bottom: 20px;">
              <label>Username</label>
              <input type="text" name="username" value="<%= user.username %>" required>
            </div>
            <div class="form-group" style="margin-bottom: 20px;">
              <label>Contact Number</label>
              <input type="text" name="contact_number" value="<%= user.contact_number %>" required>
            </div>
            <div class="form-group" style="margin-bottom: 20px;">
              <label>Account Role</label>
              <input type="text" value="<%= user.role.toUpperCase() %>" disabled style="background-color: #f8f9fa; cursor: not-allowed; color: #6c757d;">
            </div>
            <hr style="border: 0; border-top: 1px solid #eee; margin: 30px 0;">
            <h4 style="font-size: 0.9rem; margin-top: 0; margin-bottom: 15px; color: #495057;">Update Password</h4>
            <div class="form-group" style="margin-bottom: 25px;">
              <label>New Password (Leave blank to keep current)</label>
              <input type="password" name="new_password" placeholder="••••••••">
            </div>
            <button type="submit" class="btn-submit">SAVE CHANGES</button>
          </form>
        </div>
      </div>
    </div>
  </div>
</body>
</html>
